{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./remote-update.sh",
            "timeout": 120
          }
        ]
      },
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./setup.sh",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
